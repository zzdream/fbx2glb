{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fbx2glb",
  "version": "0.1.0",
  "identifier": "com.easylink.fbxglb",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "FBX -> GLB 转换器",
        "width": 980,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "resources": {
      "../../batch_fbx2glb_final.sh": "batch_fbx2glb_final.sh",
      "../../batch_fbx2glb.sh": "batch_fbx2glb.sh",
      "../../batch_gltfpack.sh": "batch_gltfpack.sh",
      "../../batch_gltf_pipeline_draco.sh": "batch_gltf_pipeline_draco.sh",
      "resources/bin/fbx2gltf": "bin/fbx2gltf",
      "resources/bin/gltfpack": "bin/gltfpack"
    }
  }
}
